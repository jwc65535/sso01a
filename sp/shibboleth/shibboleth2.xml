<SPConfig xmlns="urn:mace:shibboleth:3.0:native:sp:config"
          xmlns:conf="urn:mace:shibboleth:3.0:native:sp:config"
          clockSkew="300">

    <!--
        shibboleth2.xml — processed by sp/scripts/init.sh via envsubst.
        Variables substituted at container start:
          SP_ENTITY_ID      — SAML entityID for this SP
          IDP_ENTITY_ID     — SAML entityID of the trusted IdP
          IDP_METADATA_URL  — internal Docker URL for fetching IdP metadata
        Do NOT reference ${SP_HOSTNAME} here; shibd doesn't need it.
    -->

    <OutOfProcess tranLogFormat="%u|%s|%IDP|%i|%ac|%t|%attr|%n|%b|%E|%S|%SS|%L|%UA|%a" />

    <ApplicationDefaults entityID="${SP_ENTITY_ID}"
                         REMOTE_USER="uid persistent-id"
                         signing="true"
                         encryption="true"
                         signingAlg="http://www.w3.org/2001/04/xmldsig-more#rsa-sha256"
                         digestAlg="http://www.w3.org/2001/04/xmlenc#sha256">

        <Sessions lifetime="28800" timeout="3600" relayState="ss:mem"
                  checkAddress="false" handlerSSL="true" cookieProps="https">

            <!-- Direct IdP: no discovery service, send AuthnRequests straight to IdP -->
            <SSO entityID="${IDP_ENTITY_ID}">
                SAML2
            </SSO>

            <!-- SP metadata endpoint — useful for bootstrapping IdP trust -->
            <Handler type="MetadataGenerator"
                     Location="/Metadata"
                     signing="false" />

            <Handler type="Status" Location="/Status" acl="127.0.0.1 ::1" />

            <Handler type="Session"
                     Location="/Session"
                     showAttributeValues="false" />

            <!-- HTTP-POST ACS only (Artifact binding not used in this deployment) -->
            <Handler type="AssertionConsumerService"
                     Location="/SAML2/POST"
                     index="1"
                     Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST" />

            <Handler type="LogoutInitiator"
                     Location="/Logout"
                     conf:template="bindingTemplate.html" />

            <Handler type="SingleLogoutService"
                     Location="/SLO/Redirect"
                     Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-Redirect" />

            <Handler type="SingleLogoutService"
                     Location="/SLO/POST"
                     Binding="urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST" />
        </Sessions>

        <Errors supportContact="admin@sso.local"
                helpLocation="/about.html"
                styleSheet="/shibboleth-sp/main.css" />

        <!--
            IdP metadata fetched from the internal Docker service name.
            backingFilePath allows shibd to start even if the IdP is momentarily unreachable.
        -->
        <MetadataProvider type="XML"
                          url="${IDP_METADATA_URL}"
                          backingFilePath="/var/cache/shibboleth/idp-metadata.xml"
                          reloadInterval="7200"
                          maxRefreshDelay="300" />

        <!-- SP signing key — generated by init.sh on first boot, persisted in shib-keys volume -->
        <CredentialResolver type="File"
                            key="/etc/shibboleth/keys/sp-signing.key"
                            certificate="/etc/shibboleth/keys/sp-signing.crt"
                            use="signing" />

        <!-- SP encryption key — separate from signing to allow independent rotation -->
        <CredentialResolver type="File"
                            key="/etc/shibboleth/keys/sp-encrypt.key"
                            certificate="/etc/shibboleth/keys/sp-encrypt.crt"
                            use="encryption" />

        <AttributeExtractor type="XML"
                             validate="true"
                             reloadChanges="false"
                             path="attribute-map.xml" />

        <AttributeFilter type="XML"
                         validate="true"
                         path="attribute-policy.xml" />
    </ApplicationDefaults>

    <SecurityPolicyProvider type="XML"
                            validate="true"
                            reloadChanges="false"
                            path="security-policy.xml" />

    <ProtocolProvider type="XML"
                      validate="true"
                      reloadChanges="false"
                      path="protocols.xml" />
</SPConfig>
