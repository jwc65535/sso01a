# .env.example — copy to .env and fill in values before running `make bootstrap`
# Never commit .env to version control.

# ── Domain ──────────────────────────────────────────────────────────────────
DOMAIN=sso.local
SP_HOSTNAME=sp.sso.local
IDP_HOSTNAME=idp.sso.local
APP_HOSTNAME=app.sso.local

# ── SAML ────────────────────────────────────────────────────────────────────
SP_ENTITY_ID=https://sp.sso.local/shibboleth
SP_ACS_URL=https://sp.sso.local/Shibboleth.sso/SAML2/POST
IDP_ENTITY_ID=https://idp.sso.local/simplesaml/saml2/idp/metadata.php
IDP_METADATA_URL=http://idp/simplesaml/saml2/idp/metadata.php

# ── SimpleSAMLphp ────────────────────────────────────────────────────────────
# SSP_ADMIN_PASSWORD is in secrets/ssp_admin_password.txt
SSP_SECRET_SALT=CHANGE_THIS_TO_RANDOM_32_PLUS_CHARS
# Public URL SimpleSAMLphp uses when building redirect URLs and assertion endpoints.
# DEV:  http://idp.sso.local:8880/simplesaml/  (add 127.0.0.1 idp.sso.local to /etc/hosts)
# PROD: https://idp.sso.local/simplesaml/
IDP_BASEURLPATH=http://idp.sso.local:8880/simplesaml/

# ── Dev user passwords (LDAP, for IdP authentication only) ───────────────────
# LDAP password set for alice and bob during first-run LDAP init.
# Used only so the SimpleSAMLphp IdP can verify credentials via LDAP bind.
# PROD: remove; provision real user passwords through IAM / self-service portal.
DEV_USER_PASSWORD=changeme

# ── LDAP ────────────────────────────────────────────────────────────────────
LDAP_BASE_DN=dc=sso,dc=local
LDAP_ADMIN_DN=cn=admin,dc=sso,dc=local
LDAP_HOST=ldap
LDAP_PORT=1389
# LDAP_ADMIN_PASSWORD is in secrets/ldap_admin_password.txt
# Needed inline for healthcheck command in docker-compose:
LDAP_ADMIN_PASSWORD=changeme_in_production
# cert-writer service account — consul-template authenticates with this identity.
# Password is in secrets/ldap_cert_writer_password.txt (generated by make _gen-secrets).
# consul-template uses LDAP_BIND_DN + the secret file; never the admin account.
LDAP_BIND_DN=cn=cert-writer,ou=service-accounts,dc=sso,dc=local

# ── Vault ───────────────────────────────────────────────────────────────────
VAULT_ADDR=http://vault:8200
VAULT_DEV_ROOT_TOKEN_ID=devroot-CHANGE-ME
VAULT_PKI_MOUNT=pki
VAULT_PKI_INT_MOUNT=pki_int
VAULT_CERT_TTL=4h
VAULT_MAX_CERT_TTL=24h

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=sso
POSTGRES_ADMIN_USER=sso_admin
# POSTGRES_ADMIN_PASSWORD is in secrets/postgres_admin_password.txt (admin only)
# POSTGRES_APP_PASSWORD   is in secrets/postgres_app_password.txt  (sso_app role)
#
# DEV:  sslmode=disable — Golang app connects as sso_app via scram-sha-256
#       pg_hba.conf allows this from any internal Docker bridge IP
# PROD: sslmode=verify-full — app presents its own Vault-issued cert (CN=sso_app)
#       Add: sslcert=/path/to/sso_app.crt sslkey=/path/to/sso_app.key
#            sslrootcert=/var/lib/postgresql/ssl/ca-chain.pem
POSTGRES_SSL_MODE=disable

# ── Golang Application ───────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_BACKEND=http://app:8080
JWT_ISSUER=https://sp.sso.local
JWT_AUDIENCE=https://app.sso.local
JWT_TTL=3600

# ── TOTP passphrase (client-side only — never stored server-side) ─────────────
TOTP_ALGORITHM=SHA256
TOTP_DIGITS=8
TOTP_PERIOD=30

# ── FingerprintJS ────────────────────────────────────────────────────────────
FPJS_API_KEY=REPLACE_WITH_FPJS_PRO_API_KEY
