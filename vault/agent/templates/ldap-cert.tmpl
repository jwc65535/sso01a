{{- /*
   ldap-cert.tmpl
   Vault Agent template for a SINGLE-USER on-demand certificate push.

   Use cases:
     1. Post-enrolment: Golang app triggers a one-shot push immediately after
        Vault signs the user's CSR, so the LDAP entry is updated within seconds
        rather than waiting for the next consul-template scheduled render.
     2. Manual rotation: `make cert-rotate-user USER=alice` sets TARGET_CN and
        vault-agent renders + executes this template once.

   Required environment: TARGET_CN must be set to the user's CommonName.
   Rendered to: /vault/rendered/ldap-push-${TARGET_CN}.sh
   Executed by: the caller (Golang app or Makefile) after rendering.

   SECURITY
   ─────────
   • Authenticates to LDAP as cert-writer (not admin).
   • Reads the cert-writer password from the Docker secret file.
   • Private keys never appear in this template or its rendered output.
   • Only replaces the cert attributes for the specified CN.
*/ -}}
#!/bin/bash
# Auto-generated by vault-agent — do not edit manually.
# Pushes the latest public certificate for CN={{ env "TARGET_CN" }} to LDAP.
set -euo pipefail

TARGET_CN="{{ env "TARGET_CN" }}"
LDAP_H="ldap://{{ env "LDAP_HOST" | or "ldap" }}:{{ env "LDAP_PORT" | or "1389" }}"
BIND_DN="{{ env "LDAP_BIND_DN" | or "cn=cert-writer,ou=service-accounts,dc=sso,dc=local" }}"
BASE_DN="{{ env "LDAP_BASE_DN" | or "dc=sso,dc=local" }}"
USER_DN="uid=${TARGET_CN},ou=users,${BASE_DN}"

BIND_PW="$(cat /run/secrets/ldap_cert_writer_password 2>/dev/null || true)"
if [ -z "${BIND_PW}" ]; then
    echo "[ldap-cert] FATAL: /run/secrets/ldap_cert_writer_password is missing." >&2
    exit 1
fi

SCRATCH="$(mktemp -d)"
trap 'rm -rf "${SCRATCH}"' EXIT

MATCHED=0

{{- range secrets "pki_int/certs/" -}}
{{- $serial := . -}}
{{- with secret (printf "pki_int/cert/%s" $serial) -}}
{{- if and (not .Data.revocation_time) (not .Data.is_ca) -}}
{{- $parsed := .Data.certificate | pemCertificates -}}
{{- if $parsed -}}
{{- $cn := (index $parsed 0).Subject.CommonName }}

# ── candidate: serial={{ $serial }} cn={{ $cn }} ──────────────────────────────
if [ "{{ $cn }}" = "${TARGET_CN}" ] && [ "${MATCHED}" -eq 0 ]; then
    MATCHED=1
    SERIAL="{{ $serial }}"

    PEM_FILE="${SCRATCH}/${SERIAL}.pem"
    cat > "${PEM_FILE}" <<'HEREDOC_END'
{{ .Data.certificate }}
HEREDOC_END

    DER_FILE="${SCRATCH}/${SERIAL}.der"
    openssl x509 -in "${PEM_FILE}" -outform DER -out "${DER_FILE}" 2>/dev/null
    CERT_B64="$(base64 -w0 < "${DER_FILE}")"
    THUMBPRINT="$(openssl dgst -sha256 -binary "${DER_FILE}" \
        | openssl enc -base64 -A \
        | tr '+/' '-_' \
        | tr -d '=')"
    ENROLLED_AT="{{ timestamp "20060102150405Z" }}"

    LDIF_FILE="${SCRATCH}/${SERIAL}.ldif"
    printf 'dn: %s\nchangetype: modify\nreplace: userCertificate;binary\nuserCertificate;binary:: %s\n-\nreplace: ssoCertThumbprint\nssoCertThumbprint: %s\n-\nreplace: ssoEnrolledAt\nssoEnrolledAt: %s\n' \
        "${USER_DN}" "${CERT_B64}" "${THUMBPRINT}" "${ENROLLED_AT}" > "${LDIF_FILE}"

    if ldapmodify -x -H "${LDAP_H}" -D "${BIND_DN}" -w "${BIND_PW}" \
            -f "${LDIF_FILE}" 2>&1; then
        echo "[ldap-cert] OK: CN=${TARGET_CN} pushed (serial=${SERIAL}, thumb=${THUMBPRINT})."
    else
        echo "[ldap-cert] ERROR: ldapmodify failed for CN=${TARGET_CN}." >&2
        exit 1
    fi
fi
{{ end -}}
{{- end -}}
{{- end -}}
{{- end -}}
{{- end }}

if [ "${MATCHED}" -eq 0 ]; then
    echo "[ldap-cert] ERROR: no active cert found in Vault for CN=${TARGET_CN}." >&2
    exit 1
fi
